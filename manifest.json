{
  "manifest_version": 3,
  "name": "BugJar",
  "version": "1.1.2",
  "description": "Capture bugs in a jar — screenshot, console, network, annotations. Generates AI-ready reports.",
  "author": "Joris Gounand",
  "permissions": ["activeTab", "alarms", "scripting", "storage", "tabs"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
